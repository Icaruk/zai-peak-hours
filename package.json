{
	"name": "@icaruk/zai-peak-hours",
	"version": "0.7.0",
	"type": "module",
	"description": "OpenCode plugin to display z.ai peak hours information with automatic timezone detection",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
