		"plugin",
		"peak-hours",
		"timezone",
		"cli"
	],
	"author": "Icaruk",
	"license": "MIT",
	"peerDependencies": {
		"@opencode-ai/plugin": "^1.4.0"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"typescript": "^5.0.0"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Icaruk/zai-peak-hours.git"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
